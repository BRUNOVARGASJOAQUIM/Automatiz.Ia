# ========================================
# SHOWZAP - Configurações de Ambiente
# ========================================

# Porta da aplicação (padrão: 80)
APP_PORT=80

# Ambiente
ENVIRONMENT=production
# ENVIRONMENT=development

# ========================================
# Banco de Dados (Opcional - Futura)
# ========================================
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=showzap
# DB_PASSWORD=senha123
# DB_NAME=showzap_db

# ========================================
# n8n Webhook (Integração WhatsApp)
# ========================================
# N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/sr-altino-leads
# N8N_API_KEY=chave-secreta-aqui

# ========================================
# Twilio (WhatsApp)
# ========================================
# TWILIO_ACCOUNT_SID=seu-sid
# TWILIO_AUTH_TOKEN=seu-token
# TWILIO_PHONE_NUMBER=+5511999999999

# ========================================
# WordPress (Se integrado)
# ========================================
# WP_SITE_URL=https://seu-site-wordpress.com
# WP_REST_API_URL=https://seu-site-wordpress.com/wp-json/wp/v2

# ========================================
# Logging
# ========================================
# LOG_LEVEL=info
# LOG_FORMAT=json

# ========================================
# Segurança
# ========================================
# ENABLE_CORS=true
# CORS_ORIGIN=https://seu-site.com
# SESSION_SECRET=seu-secret-aleatorio
