# ════════════════════════════════════════════
# CondoZap — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# ════════════════════════════════════════════

# ── POSTGRES ─────────────────────────────────
POSTGRES_PASSWORD=troque_por_senha_forte

# ── N8N ──────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=troque_por_senha_forte

# URL pública onde o n8n estará acessível
# Local com ngrok:  https://abc123.ngrok-free.app
# VPS:              https://n8n.seudominio.com.br
N8N_WEBHOOK_URL=https://SEU-DOMINIO-OU-NGROK.com
N8N_HOST=localhost

# ── EVOLUTION API ────────────────────────────
# Chave de acesso à Evolution API (crie uma senha forte)
EVOLUTION_API_KEY=troque_por_chave_forte

# URL pública da Evolution API
# Local com ngrok:  https://xyz789.ngrok-free.app
# VPS:              https://evolution.seudominio.com.br
EVOLUTION_PUBLIC_URL=https://SEU-DOMINIO-OU-NGROK.com:8080

# ════════════════════════════════════════════
# VARIÁVEIS DO N8N (configurar em Settings → Variables)
# Copie e cole essas chaves no painel do n8n
# ════════════════════════════════════════════

# Condomínio
# CONDO_NAME=Residencial das Flores

# Evolution API (preencher com os valores acima)
# EVOLUTION_API_URL=http://condozap-evolution:8080   ← dentro do Docker
# EVOLUTION_API_INSTANCE=condo-principal
# EVOLUTION_API_KEY=<mesma chave acima>

# Dashboard webhook (URL do workflow 2)
# DASHBOARD_WEBHOOK_URL=https://SEU-N8N.com/webhook/cz-dashboard

# Responsáveis WhatsApp (55 + DDD + número, sem espaços)
# RESP_ZELADOR=5511999990001
# RESP_SINDICO=5511999990002
# RESP_PORTARIA=5511999990003
# RESP_FINANCEIRO=5511999990004

# Claude AI
# ANTHROPIC_API_KEY=sk-ant-...

# Google Workspace
